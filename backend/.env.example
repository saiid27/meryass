# Copy this file to .env and fill in real values before running.
# Never commit .env to version control.

DATABASE_URL=postgresql://meryas_user:YOUR_DB_PASSWORD@localhost:5432/meryas_db
SECRET_KEY=change-this-to-a-random-secret-key
JWT_SECRET_KEY=change-this-to-a-different-random-secret
PORT=5000

# Optional — set to 'production' to enable strict secret checks
# FLASK_ENV=production

# Optional — comma-separated CORS origins for production
# CORS_ORIGINS=https://yourdomain.com

# Development only — fill public rooms with playable bots
# AUTO_FILL_PUBLIC_ROOMS=true
